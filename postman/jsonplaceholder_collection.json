{
  "info": {
    "name": "JSONPlaceholder API",
    "_postman_id": "bmontes-qa-collection-v1",
    "description": "API test collection for JSONPlaceholder REST API.\nCovers: Posts, Users, Comments, Todos.\nAuthor: Belén Montes · github.com/bmontes1067",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://jsonplaceholder.typicode.com",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Posts",
      "item": [
        {
          "name": "GET all posts",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Returns 100 posts', () => {",
                  "  pm.expect(pm.response.json()).to.have.lengthOf(100);",
                  "});",
                  "pm.test('Response time is under 2000ms', () => {",
                  "  pm.expect(pm.response.responseTime).to.be.below(2000);",
                  "});",
                  "pm.test('Each post has required fields', () => {",
                  "  pm.response.json().forEach(post => {",
                  "    pm.expect(post).to.have.all.keys('userId', 'id', 'title', 'body');",
                  "    pm.expect(post.title).to.be.a('string').and.not.empty;",
                  "  });",
                  "});",
                  "pm.test('Content-Type is application/json', () => {",
                  "  pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
                  "});"
                ]
              }
            }
          ],
          "request": { "method": "GET", "url": "{{base_url}}/posts" }
        },
        {
          "name": "GET single post",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => { pm.response.to.have.status(200); });",
                  "pm.test('Returns correct post id', () => {",
                  "  pm.expect(pm.response.json().id).to.eql(1);",
                  "});",
                  "pm.test('Post has all required fields', () => {",
                  "  pm.expect(pm.response.json()).to.have.all.keys('userId', 'id', 'title', 'body');",
                  "});"
                ]
              }
            }
          ],
          "request": { "method": "GET", "url": "{{base_url}}/posts/1" }
        },
        {
          "name": "GET post — 404 not found",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 404', () => { pm.response.to.have.status(404); });",
                  "pm.test('Response body is empty object', () => {",
                  "  pm.expect(pm.response.json()).to.eql({});",
                  "});"
                ]
              }
            }
          ],
          "request": { "method": "GET", "url": "{{base_url}}/posts/99999" }
        },
        {
          "name": "POST create post",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', () => { pm.response.to.have.status(201); });",
                  "pm.test('Returns created post with id', () => {",
                  "  const post = pm.response.json();",
                  "  pm.expect(post).to.have.property('id');",
                  "  pm.expect(post.title).to.eql('QA Automation Post');",
                  "  pm.expect(post.userId).to.eql(1);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/posts",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"title\": \"QA Automation Post\", \"body\": \"Created by Postman\", \"userId\": 1}"
            }
          }
        },
        {
          "name": "PUT update post",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => { pm.response.to.have.status(200); });",
                  "pm.test('Title was updated', () => {",
                  "  pm.expect(pm.response.json().title).to.eql('Updated Title');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/posts/1",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"id\": 1, \"title\": \"Updated Title\", \"body\": \"Updated body\", \"userId\": 1}"
            }
          }
        },
        {
          "name": "PATCH partial update post",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => { pm.response.to.have.status(200); });",
                  "pm.test('Only title was patched', () => {",
                  "  const post = pm.response.json();",
                  "  pm.expect(post.title).to.eql('Patched Title');",
                  "  pm.expect(post.id).to.eql(1);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/posts/1",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"title\": \"Patched Title\"}" }
          }
        },
        {
          "name": "DELETE post",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => { pm.response.to.have.status(200); });",
                  "pm.test('Response body is empty', () => {",
                  "  pm.expect(pm.response.json()).to.eql({});",
                  "});"
                ]
              }
            }
          ],
          "request": { "method": "DELETE", "url": "{{base_url}}/posts/1" }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "GET all users",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => { pm.response.to.have.status(200); });",
                  "pm.test('Returns 10 users', () => {",
                  "  pm.expect(pm.response.json()).to.have.lengthOf(10);",
                  "});",
                  "pm.test('Each user has email', () => {",
                  "  pm.response.json().forEach(u => {",
                  "    pm.expect(u.email).to.include('@');",
                  "  });",
                  "});"
                ]
              }
            }
          ],
          "request": { "method": "GET", "url": "{{base_url}}/users" }
        },
        {
          "name": "GET user posts",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => { pm.response.to.have.status(200); });",
                  "pm.test('All posts belong to userId 1', () => {",
                  "  pm.response.json().forEach(p => {",
                  "    pm.expect(p.userId).to.eql(1);",
                  "  });",
                  "});"
                ]
              }
            }
          ],
          "request": { "method": "GET", "url": "{{base_url}}/users/1/posts" }
        }
      ]
    },
    {
      "name": "Comments",
      "item": [
        {
          "name": "GET comments by postId",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => { pm.response.to.have.status(200); });",
                  "pm.test('Returns 5 comments for post 1', () => {",
                  "  pm.expect(pm.response.json()).to.have.lengthOf(5);",
                  "});",
                  "pm.test('All comments have valid email', () => {",
                  "  pm.response.json().forEach(c => {",
                  "    pm.expect(c.email).to.include('@');",
                  "  });",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/comments?postId=1",
              "host": ["{{base_url}}"],
              "path": ["comments"],
              "query": [{ "key": "postId", "value": "1" }]
            }
          }
        }
      ]
    },
    {
      "name": "Todos",
      "item": [
        {
          "name": "GET completed todos",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => { pm.response.to.have.status(200); });",
                  "pm.test('All returned todos are completed', () => {",
                  "  pm.response.json().forEach(t => {",
                  "    pm.expect(t.completed).to.be.true;",
                  "  });",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/todos?completed=true",
              "host": ["{{base_url}}"],
              "path": ["todos"],
              "query": [{ "key": "completed", "value": "true" }]
            }
          }
        }
      ]
    }
  ]
}
